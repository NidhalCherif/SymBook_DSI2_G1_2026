{% extends 'base.html.twig' %}

{% block title %}Nos livres{% endblock %}

{% block body %}
<h1>Liste des livres</h1>
    <div class="text-end">
    <a href="{{ url('admin_livres_add') }}"  class="btn btn-primary">Ajouter un nouveau livre</a>
    </div>
    <table class="table mt-1">
        <tr class="table-primary">
            <th>Titre</th>
            <th>ISBN</th>
            <th>Editeur</th>
            <th>Date d'édition</th>
            <th>Prix</th>
            <th>Catégorie</th>
            <th colspan="3">Action</th>

        </tr>
        {% for livre in livres %}
            <tr>
                <td>{{ livre.titre }}</td>
                <td>{{ livre.isbn }}</td>
                <td>{{ livre.editeur }}</td>
                <td>{{ livre.dateEdition|date('d-m-Y') }}</td>
                <td>{{ livre.prix }}</td>
                <td>{{ livre.cat.libelle }}</td>
                <td><a href="{{ url('admin_livres_show',{'id':livre.id}) }}">Voir détail</a></td>
                <td><a href="#">Editer</a></td>
                <td><a href="{{ url('admin_livres_delete',{'id':livre.id}) }}">Supprimer</a></td>


            </tr>
        {% endfor %}
    </table>
    <div class="navigation">
        {{ knp_pagination_render(livres) }}
    </div>
{% endblock %}
